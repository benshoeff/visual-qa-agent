{
  "installCommand": "npm install --prefix client",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://visual-qa-agent.onrender.com/api/$1" },
    { "source": "/images/(.*)", "destination": "https://visual-qa-agent.onrender.com/images/$1" }
  ]
}
